# Set to "false" to use environment variables instead of Secrets Manager (local dev)
USE_SECRETS_MANAGER=false

# Database (RDS PostgreSQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=salesdb
DB_USER=salesadmin
DB_PASSWORD=your_db_password

# AWS
AWS_REGION=us-east-1

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/sales-sell-notes

# S3
S3_BUCKET_NAME=sales-pdfs-123456789012

# Inter-service URLs
NOTIFIER_URL=http://localhost:8003
API_BASE_URL=http://localhost:8000
